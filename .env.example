# Application
APP_ENV=development
APP_PORT=8088
APP_NAME=payment-gateway

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=payment_gateway
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Idempotency
IDEMPOTENCY_TTL=86400 # 24 hours in seconds

# Outbox
OUTBOX_WORKER_INTERVAL_SECONDS=5 # Interval for the outbox worker to check for new messages (in seconds)

